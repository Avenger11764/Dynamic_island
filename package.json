{
  "name": "dynamic-island",
  "private": true,
  "version": "1.0.0",
  "main": "main.js",
  "author": "Avinash",
  "description": "A Dynamic Island for Windows.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:start": "electron .",
    "pack": "vite build && electron-builder --dir",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.dynamic.island",
    "productName": "Dynamic Island",
    "win": {
      "target": "nsis"
    },
    "directories": {
      "output": "release",
      "buildResources": "build_dist"
    },
    "files": [
      "secrets.js",
      ".env",
      "main.js",
      "smtc-worker.js",
      "build_dist/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "@coooookies/windows-smtc-monitor": "^1.0.12",
    "dotenv": "^17.4.2",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.360.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "spotify-web-api-node": "^5.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "vite": "^8.0.8"
  }
}
